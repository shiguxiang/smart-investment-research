# === DashScope (阿里云) ===
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# === Milvus ===
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=review_materials

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# === 模型配置 ===
LLM_MODEL=qwen-max
EMBEDDING_MODEL=text-embedding-v3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# === 检索参数 ===
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20
VECTOR_WEIGHT=0.5
KEYWORD_WEIGHT=0.3
METADATA_WEIGHT=0.2

# === 服务配置 ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
